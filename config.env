# =====================================================================
# xrdp-fleet — single source of truth for the build & publish pipeline
# =====================================================================
# Edit this file to change versions, targets, or identity, then re-run
# the build (locally via scripts/build-local.sh, or in CI by pushing a
# v* tag). Everything downstream reads these values.

# ---- GitHub / Pages -------------------------------------------------
GH_USER="norandom"
GH_REPO="xrdp-fleet"
PAGES_URL="https://norandom.github.io/xrdp-fleet"

# ---- Target Ubuntu codenames ---------------------------------------
# One signed apt suite is published per codename. Each .deb is built
# INSIDE the matching distro container so its dependencies match exactly
# (this is the core fix for "dependency explosion" / cross-distro breakage).
CODENAMES="noble jammy kali-rolling"   # noble=24.04/Mint22 · jammy=22.04/Mint21 · kali-rolling=Kali (Debian-based)

# ---- Fleet rebuild counter -----------------------------------------
# Bump this (1 -> 2 -> ...) to ship a fresh rebuild of the SAME upstream
# version; clients auto-upgrade because the new version sorts higher.
FLEET_REV="3"

# ---- Pinned Debian source packages (from sid / deb.debian.org) ------
# To take a newer xrdp, bump these to the current sid version
# (see https://packages.debian.org/sid/xrdp). The orig tarball uses the
# upstream version only; the .dsc/.debian.tar use upstream-debrev.
XRDP_UPSTREAM="0.10.6"
XRDP_DEBREV="5"                  # -> xrdp_0.10.6-5.dsc

XORGXRDP_UPSTREAM="0.10.5"       # matching minor for the 0.10.x series (no 0.10.6 xorgxrdp exists)
XORGXRDP_DEBREV="2"              # -> xorgxrdp_0.10.5-2.dsc
XORGXRDP_EPOCH="1"               # xorgxrdp carries a Debian epoch (1:)

# ---- Debian source mirrors -----------------------------------------
# Primary is the live sid pool. When sid moves past the pinned version
# the .dsc 404s — bump the versions above (or recover the exact files
# from snapshot.debian.org and set SNAPSHOT_POOL to that timestamped base).
DEBIAN_POOL="https://deb.debian.org/debian/pool/main/x"
SNAPSHOT_POOL=""                 # optional fallback, e.g. https://snapshot.debian.org/archive/debian/20260101T000000Z/pool/main/x

# ---- GPG signing identity ------------------------------------------
# scripts/gpg-keygen.sh creates this key. Its PRIVATE half goes into the
# GitHub Actions secret GPG_PRIVATE_KEY; only the public pubkey.gpg ships.
GPG_NAME="xrdp-fleet apt repo"
GPG_EMAIL="wishinet@gmail.com"

# ---- apt repo identity (MUST match the client pin in client/) -------
REPO_ORIGIN="fleet-xrdp"
REPO_LABEL="fleet-xrdp"
