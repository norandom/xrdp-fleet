-    0x66, 0x66, 0x77, 0x88, 0x98
+    0x66, 0x66, 0x77, 0x88, 0x98, /* [0] luma (unchanged) */
+    0x66, 0x66, 0x66, 0x77, 0x87  /* [1] chroma: finer mid/high, less hue (fleet) */
 };
